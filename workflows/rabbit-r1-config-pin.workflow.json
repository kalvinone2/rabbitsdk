      "parameters": {
        "jsCode": "const expectedPin = 'REPLACE_WITH_PIN';\nconst config = {\n  v: 2,\n  name: 'Mind Drop',\n  endpoint: 'https://n8n.calvonavarro.com/webhook/rabbit-r1-notion-v0',\n  token: 'REPLACE_WITH_RABBIT_TOKEN',\n  lang: 'es-ES',\n  speak: true\n};\n\nfunction parsePayload(input) {\n  const direct = input.payload ?? input.body?.payload ?? input.body ?? input;\n  if (typeof direct === 'string') {\n    try { return JSON.parse(direct); } catch (error) { return { pin: direct }; }\n  }\n  return direct || {};\n}\n\nconst payload = parsePayload($json);\nconst pin = String(payload.pin || payload.code || '').trim();\nconst ok = Boolean(expectedPin && !expectedPin.startsWith('REPLACE_WITH_') && pin === expectedPin);\n\nreturn [{\n  json: ok\n    ? { ok: true, status: 'ok', config }\n    : { ok: false, revoked: true, status: 'revoked', reply: 'PIN invalido' }\n}];"
      },
